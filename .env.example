# Must match mirage-bank's .env exactly — same Aura instance, same secret.
# Copy the real values from mirage-bank/.env, do not generate new ones.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-auradb-password-here
NEO4J_DATABASE=neo4j
JWT_SECRET=must-match-mirage-bank-jwt-secret-exactly
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# The single super-owner account, mirroring mirage-bank's OWNER_EMAIL. Set
# this to YOUR account email once the casino has privileged admin routes of
# its own (see backend/dependencies.py::get_current_owner). Not yet used by
# any route, but the check fails closed (403) regardless, same as the bank.
OWNER_EMAIL=you@example.com

# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:8914,http://127.0.0.1:8914

APP_ENV=development

# PORT is provided automatically by Render/Railway; no need to set it locally.
# Start command in production: uvicorn main:app --host 0.0.0.0 --port $PORT
