{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": ["pip install -r backend/requirements.txt"]
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --app-dir backend --host 0.0.0.0 --port $PORT"
  }
}
